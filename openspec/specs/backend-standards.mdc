## Testing Standards

### Coverage Threshold

Minimum 90% for branches, functions, and statements.

### Structure

```
tests/
├── unit/
│   ├── domain/
│   ├── application/
│   └── infrastructure/
└── integration/        # Tests against a real test database (Supabase test project or local PG)
```

### Unit Test Pattern (pytest + AAA)

```python
# tests/unit/application/test_dataset_service.py
import pytest
from unittest.mock import AsyncMock, MagicMock
from app.application.services.dataset_service import DatasetService
from app.domain.models.dataset import Dataset
from datetime import datetime, UTC


@pytest.fixture
def mock_repository() -> AsyncMock:
    repo = AsyncMock()
    return repo


@pytest.fixture
def service(mock_repository: AsyncMock) -> DatasetService:
    return DatasetService(mock_repository)


@pytest.mark.asyncio
async def test_get_dataset_returns_none_when_not_found(
    service: DatasetService, mock_repository: AsyncMock
) -> None:
    # Arrange
    mock_repository.find_by_id.return_value = None

    # Act
    result = await service.get_dataset("non-existent-id")

    # Assert
    assert result is None
    mock_repository.find_by_id.assert_called_once_with("non-existent-id")


@pytest.mark.asyncio
async def test_create_dataset_saves_and_returns_response(
    service: DatasetService, mock_repository: AsyncMock
) -> None:
    # Arrange
    from app.presentation.schemas.dataset_schemas import CreateDatasetRequest
    payload = CreateDatasetRequest(
        title="Restaurants CABA", category="restaurants", zone="CABA", price_usd=29.99
    )
    mock_repository.save.return_value = None

    # Act
    result = await service.create_dataset(payload)

    # Assert
    assert result.title == "Restaurants CABA"
    assert result.price_usd == 29.99
    mock_repository.save.assert_called_once()
```

### Router Test Pattern

```python
# tests/unit/presentation/test_datasets_router.py
import pytest
from httpx import AsyncClient, ASGITransport
from unittest.mock import AsyncMock
from main import app
from app.infrastructure.dependencies import get_dataset_service


@pytest.mark.asyncio
async def test_get_dataset_returns_404_when_not_found() -> None:
    mock_service = AsyncMock()
    mock_service.get_dataset.return_value = None

    app.dependency_overrides[get_dataset_service] = lambda: mock_service

    async with AsyncClient(transport=ASGITransport(app=app), base_url="http://test") as client:
        response = await client.get("/datasets/non-existent-id")

    assert response.status_code == 404
    app.dependency_overrides.clear()
```

