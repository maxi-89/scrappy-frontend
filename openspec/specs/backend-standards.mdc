## Application Layer

Application services orchestrate domain logic. They:
- Receive typed input (Pydantic schemas or plain dicts)
- Validate input and enforce business rules
- Call repository interfaces
- Return typed output (domain entities or plain dicts)

```python
# app/application/services/dataset_service.py
import uuid
from datetime import datetime, UTC
from app.domain.models.dataset import Dataset
from app.domain.repositories.i_dataset_repository import IDatasetRepository
from app.presentation.schemas.dataset_schemas import DatasetResponse, CreateDatasetRequest


class DatasetService:
    def __init__(self, repository: IDatasetRepository) -> None:
        self._repository = repository

    async def list_datasets(
        self, category: str | None = None, zone: str | None = None
    ) -> list[DatasetResponse]:
        datasets = await self._repository.find_all(category=category, zone=zone)
        return [DatasetResponse.model_validate(d.__dict__) for d in datasets]

    async def get_dataset(self, dataset_id: str) -> DatasetResponse | None:
        dataset = await self._repository.find_by_id(dataset_id)
        if dataset is None:
            return None
        return DatasetResponse.model_validate(dataset.__dict__)

    async def create_dataset(self, payload: CreateDatasetRequest) -> DatasetResponse:
        dataset = Dataset(
            id=str(uuid.uuid4()),
            title=payload.title,
            category=payload.category,
            zone=payload.zone,
            record_count=0,
            price_usd=payload.price_usd,
            created_at=datetime.now(UTC),
        )
        await self._repository.save(dataset)
        return DatasetResponse.model_validate(dataset.__dict__)
```

**Rules:**
- Services must not import `fastapi`, `sqlalchemy`, or Supabase SDK directly
- Each method has a single responsibility
- Return types must be fully typed (no `Any`)
- Use constructor injection for dependencies

