## Error Handling

### Route-Level Errors (`error.tsx`)

```tsx
// app/[feature]/error.tsx
'use client';

export default function ErrorPage({ error, reset }: { error: Error; reset: () => void }) {
  return (
    <div className="flex flex-col items-center justify-center min-h-[400px] gap-4">
      <p className="text-red-600 font-medium">{error.message}</p>
      <button onClick={reset} className="px-4 py-2 bg-gray-100 rounded-md hover:bg-gray-200">
        Try again
      </button>
    </div>
  );
}
```

### Component-Level Errors

Use a local error state for form submissions and mutations:

```tsx
const [error, setError] = useState<string | null>(null);

const handleSubmit = async () => {
  setError(null);
  try {
    await createOrder(data);
  } catch (err) {
    setError(err instanceof Error ? err.message : 'Something went wrong');
  }
};
```

Display errors inline near the action that caused them, not in a global toast unless the project has an established notification system.

